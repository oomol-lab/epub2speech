# Azure Speech Service Configuration
# Get your credentials from: https://portal.azure.com/

# Azure Speech Service subscription key
AZURE_SPEECH_KEY=your_azure_speech_subscription_key_here

# Azure Speech Service region (e.g., eastasia, westus, etc.)
AZURE_SPEECH_REGION=your_azure_speech_region_here

# Doubao (ByteDance) TTS Configuration
# For official API: https://www.volcengine.com/docs/6561/1257584

DOUBAO_ACCESS_TOKEN=your_doubao_access_token_here
DOUBAO_BASE_URL=https://example.org

# Qwen (Alibaba) TTS Configuration
# For official API: https://help.aliyun.com/zh/model-studio/qwen-tts

QWEN_ACCESS_TOKEN=your_qwen_access_token_here
QWEN_BASE_URL=https://example.org
